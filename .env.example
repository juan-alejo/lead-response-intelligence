# Copy to .env and fill with real credentials. Never commit .env.
#
# All external services can run in MOCK mode for local dev / CI. Set
# <SERVICE>_MODE=real to use a live API, mock to use the bundled fake.

# --- Anthropic Claude API (form classification) ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MODE=mock            # mock | real

# --- Google Places API (prospect ingestion) ---
GOOGLE_PLACES_API_KEY=
PLACES_MODE=mock            # mock | real

# --- Airtable (system of record) ---
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
STORAGE_BACKEND=sqlite      # sqlite | airtable

# --- SQLite fallback path (when STORAGE_BACKEND=sqlite) ---
SQLITE_PATH=data/pipeline.sqlite

# --- Twilio (response monitoring, SMS + voice) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MODE=mock            # mock | real

# --- Gmail (response monitoring, email) ---
GMAIL_CREDENTIALS_PATH=
GMAIL_TOKEN_PATH=
GMAIL_MODE=mock             # mock | real

# --- Mock fixtures (paths to JSON files used when *_MODE=mock) ---
MOCK_PLACES_FIXTURE=data/fixtures/places.json
MOCK_SMS_FIXTURE=data/fixtures/sms_responses.json
MOCK_EMAIL_FIXTURE=data/fixtures/email_responses.json

# --- General ---
LOG_LEVEL=INFO
REPORT_OUTPUT_DIR=reports
