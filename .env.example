# Copy to .env and fill with real credentials. Never commit .env.
#
# All external services can run in MOCK mode for local dev / CI. Set
# <SERVICE>_MODE=real to use a live API, mock to use the bundled fake.

# --- Anthropic Claude API (form classification) ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MODE=mock            # mock | real

# --- Google Places API (prospect ingestion) ---
GOOGLE_PLACES_API_KEY=
PLACES_MODE=mock            # mock | real

# --- Airtable (system of record) ---
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
STORAGE_BACKEND=sqlite      # sqlite | airtable

# --- SQLite fallback path (when STORAGE_BACKEND=sqlite) ---
SQLITE_PATH=data/pipeline.sqlite

# --- Twilio (response monitoring, SMS + voice) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MODE=mock            # mock | real

# --- Gmail (response monitoring, email) ---
GMAIL_CREDENTIALS_PATH=
GMAIL_TOKEN_PATH=
GMAIL_MODE=mock             # mock | real

# --- Mock fixtures (paths to JSON files used when *_MODE=mock) ---
MOCK_PLACES_FIXTURE=data/fixtures/places.json
MOCK_SMS_FIXTURE=data/fixtures/sms_responses.json
MOCK_EMAIL_FIXTURE=data/fixtures/email_responses.json

# --- Dashboard auth (optional) ---
# If set, the Streamlit dashboard requires this password to access.
# Leave blank for open access (local dev / internal deployments).
DASHBOARD_PASSWORD=

# --- Phase 2 — automated form submission ---
# Gated behind this flag. When false, Phase 1 behavior is byte-identical
# to pre-Phase-2. See docs/PHASE_2_SPEC.md for the commercial / live-
# submitter engagement.
PHASE_2_ENABLED=false
SUBMITTER_MODE=mock             # mock | real | disabled
SUBMITTER_BATCH_LIMIT=50

# Test-lead identity (what the submitter types into every form).
# In demo mode these stay as defaults; for real clients, swap them for
# an identity the operator owns so replies flow back to them.
LEAD_FULL_NAME=Demo Tester
LEAD_EMAIL=demo+leadresponse@example.com
LEAD_PHONE=+15555550100
LEAD_COMPANY=Lead Response Intelligence Demo
LEAD_MESSAGE=Hi — checking how quickly your team responds to inbound contact. This is an automated deliverability test.

# --- General ---
LOG_LEVEL=INFO
REPORT_OUTPUT_DIR=reports
